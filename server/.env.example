# Скопируй в server/.env и подставь свои значения. Файл .env в репозиторий не коммитится.

# Токен бота из @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Порт сервера (по умолчанию 3000)
PORT=3000

# Хост (0.0.0.0 — слушать все интерфейсы)
HOST=0.0.0.0

# Максимальный возраст initData в секундах (защита от replay). 0 — не проверять.
INITDATA_MAX_AGE=86400
